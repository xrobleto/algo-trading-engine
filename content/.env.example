# =============================================================================
# CONTENT AUTOMATION ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# ANTHROPIC (Claude AI for caption generation)
# Get from: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# BUFFER (Instagram scheduling)
# Setup:
# 1. Create account: https://buffer.com
# 2. Connect Instagram Business account
# 3. Get API token: https://buffer.com/developers/api
# 4. Run: python post_to_buffer.py --profiles to get profile ID
# -----------------------------------------------------------------------------
BUFFER_ACCESS_TOKEN=your_buffer_access_token
BUFFER_PROFILE_ID=your_instagram_profile_id

# -----------------------------------------------------------------------------
# BEEHIIV (Newsletter platform)
# Setup:
# 1. Create account: https://beehiiv.com
# 2. Settings > Integrations > API > Create API Key
# 3. Copy Publication ID from Settings > General
# -----------------------------------------------------------------------------
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx

# -----------------------------------------------------------------------------
# IMGUR (Image hosting for Buffer - optional)
# Get from: https://api.imgur.com/oauth2/addclient
# Only needed if you want images in your Instagram posts via Buffer
# -----------------------------------------------------------------------------
IMGUR_CLIENT_ID=your_imgur_client_id

# -----------------------------------------------------------------------------
# YOUR BRAND
# -----------------------------------------------------------------------------
INSTAGRAM_HANDLE=@yourhandle
WEBSITE_URL=https://yoursite.com

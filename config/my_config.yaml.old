# Master Trading Bot Configuration
# Multi-strategy system combining Momentum Breakout + VWAP Scalping

# =============================================================================
# API CREDENTIALS
# =============================================================================
alpaca:
  api_key: "PKABNNT7OMXIL2RO4EGXWU2MA5"
  api_secret: "PJ8QQCRekjXnpFkck7yx2VdVXmZYoX7EL6LkpoKyceP"
  paper: true  # Set to false for live trading

polygon_api_key: "eskzZ5O4QQyYpS5TsA3pe5WMeepeaxmW"  # For news and ticker details

# =============================================================================
# TRADING UNIVERSE
# =============================================================================
# Symbols to scan for trading opportunities
universe:
  # High-volume liquid stocks (VWAP scalping)
  - AAPL
  - MSFT
  - NVDA
  - TSLA
  - AMD
  - META
  - GOOGL
  - AMZN
  - SPY
  - QQQ

  # Momentum candidates (lower float, explosive potential)
  - RIOT
  - MARA
  - COIN
  - PLTR
  - SNOW
  - CRWD
  - DDOG
  - NET

# =============================================================================
# DYNAMIC UNIVERSE DISCOVERY (Recommended!)
# =============================================================================
# Automatically discover high-volume movers beyond core universe
# This significantly improves opportunity discovery
dynamic_universe:
  enabled: true  # Set to false to use only static universe
  scan_interval_sec: 300  # Scan for new movers every 5 minutes
  min_rvol: 2.5  # Minimum relative volume (2.5x+ vs 20-day avg)
  min_price: 10.0  # Minimum stock price
  max_price: 1000.0  # Maximum stock price
  min_volume_usd: 50000000  # Minimum $50M daily dollar volume (liquidity)
  max_size: 20  # Max number of dynamic symbols to add

# How it works:
# - Every 5 minutes, scans all stocks via Polygon snapshots API
# - Filters for high RVOL (2.5x+), adequate price range, high liquidity
# - Adds top 20 movers to universe (sorted by RVOL)
# - Automatically rotates as new movers emerge
# - Example: Catches NVDA earnings day, small-cap squeeze plays, etc.

# =============================================================================
# MARKET REGIME FILTERS
# =============================================================================
market_filters:
  min_spy_rvol: 0.8  # Minimum SPY relative volume (pause if < 0.8x)

# =============================================================================
# RISK MANAGEMENT
# =============================================================================
risk:
  # Portfolio-level limits
  max_daily_loss_pct: 0.05  # 5% max daily loss
  max_concurrent_positions: 8  # Maximum open positions at once
  max_consecutive_losses: 5  # Pause after 5 losses in a row

  # Position-level limits
  max_position_risk_pct: 0.02  # Base risk per trade (1-3% adaptive)

  # Circuit breaker
  circuit_breaker_drawdown: 0.10  # Trigger at 10% drawdown (1 hour cooldown)

# =============================================================================
# STRATEGY: MOMENTUM BREAKOUT (40% capital allocation)
# =============================================================================
strategies:
  momentum_breakout:
    enabled: true

    # Entry filters
    min_gap_pct: 3.0  # Minimum gap-up percentage
    min_volume_ratio: 2.0  # Minimum volume vs 20-day average
    max_float: 50000000  # Maximum shares outstanding (50M)
    min_price: 3.0  # Minimum stock price
    max_price: 100.0  # Maximum stock price

    # Risk/reward
    atr_stop_multiplier: 2.0  # Stop loss = 2x ATR below entry
    profit_target_r: 2.0  # Profit target = 2R (2x risk)

    # Quality scoring (affects position size)
    # Gap >= 10%: +0.3, Volume >= 5x: +0.4, ATR >= 2.0: +0.3
    # Total score: 0.5-1.5 (multiplies base risk)

  # ===========================================================================
  # STRATEGY: VWAP SCALPING (40% capital allocation)
  # ===========================================================================
  vwap_scalping:
    enabled: true

    # Entry filters
    min_price: 20.0  # Minimum stock price
    max_price: 500.0  # Maximum stock price
    min_avg_volume: 5000000  # Minimum 20-day average volume
    max_vwap_distance_pct: 0.5  # Max distance from VWAP for entry (0.5%)

    # Risk/reward
    profit_target_pct: 1.0  # 1% profit target
    stop_loss_pct: 0.5  # 0.5% stop loss

    # Quality scoring
    # Distance < 0.2%: +0.5, Volume >= 3x: +0.5
    # Total score: 0.5-1.5

# =============================================================================
# BOT BEHAVIOR
# =============================================================================
scan_interval_seconds: 60  # How often to scan for new setups
close_all_on_exit: false  # Close all positions on bot shutdown

# =============================================================================
# STATE PERSISTENCE
# =============================================================================
state_file: "master_bot_state.json"  # Bot state (positions, P&L, etc.)
log_dir: "logs"  # Directory for log files

# =============================================================================
# SAFETY SYSTEMS
# =============================================================================
kill_switch_file: "KILL_SWITCH.txt"  # Create this file to stop bot immediately
# Alternative: Set environment variable TRADING_KILL_SWITCH=1

# =============================================================================
# ALERTING
# =============================================================================
alerts:
  # Slack notifications (optional)
  slack_webhook: ""  # Your Slack webhook URL

  # Email alerts (optional, critical errors only)
  email:
    enabled: false
    smtp_server: "smtp.gmail.com"
    smtp_port: 587
    from_email: "xrobleto@gmail.com"
    to_email: "xrobleto@gmail.com"
    password: "uwdz yfln fpnf pgaw"

  # Sound alerts (optional, critical only)
  sound_enabled: false

# =============================================================================
# EXPECTED PERFORMANCE (Based on Design Document)
# =============================================================================
# Win Rate: 45-55%
# Average R-Multiple: 1.8R
# Sharpe Ratio: 1.2-2.0
# Max Drawdown: <15%
# Daily Trades: 4-8
# Capital Efficiency: ~60% deployed
